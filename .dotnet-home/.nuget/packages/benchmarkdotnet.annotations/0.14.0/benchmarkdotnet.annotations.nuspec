<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>BenchmarkDotNet.Annotations</id>
    <version>0.14.0</version>
    <authors>.NET Foundation and contributors</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>package-icon.png</icon>
    <projectUrl>https://github.com/dotnet/BenchmarkDotNet</projectUrl>
    <description>Powerful .NET library for benchmarking</description>
    <copyright>.NET Foundation and contributors</copyright>
    <tags>benchmark benchmarking performance</tags>
    <repository type="git" url="https://github.com/dotnet/BenchmarkDotNet" commit="cf882d378d51a6998aad43ca9caa29c19d122b87" />
    <dependencies>
      <group targetFramework=".NETStandard1.0">
        <dependency id="NETStandard.Library" version="1.6.1" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0" />
    </dependencies>
  </metadata>
</package>