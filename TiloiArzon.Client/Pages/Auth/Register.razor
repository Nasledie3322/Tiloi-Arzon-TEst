@page "/register"
@using System.ComponentModel.DataAnnotations
@inject AuthApi AuthApi
@inject NavigationManager Nav

<div class="auth-shell">
    <div class="auth-card">
        <h1>Create account</h1>
        <p class="muted">Register to start saving favorites and placing orders.</p>

        <EditForm Model="_model" OnValidSubmit="OnSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="field">
                <label>Email</label>
                <InputText class="input" @bind-Value="_model.Email" />
            </div>

            <div class="field">
                <label>Password</label>
                <InputText class="input" type="password" @bind-Value="_model.Password" />
            </div>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="alert alert-danger">@_error</div>
            }

            <button class="btn btn-primary w-100" disabled="@_busy" type="submit">
                @(_busy ? "Creating…" : "Create account")
            </button>
        </EditForm>

        <div class="auth-footer">
            <a href="/login">Already have an account?</a>
        </div>
    </div>
</div>

@code {
    private bool _busy;
    private string? _error;
    private RegisterModel _model = new();

    private async Task OnSubmit()
    {
        _busy = true;
        _error = null;
        try
        {
            var result = await AuthApi.RegisterAsync(new TiloiArzon.Client.Models.RegisterDto
            {
                Email = _model.Email,
                Password = _model.Password
            });

            if (result == null)
            {
                _error = "This email is already registered.";
                return;
            }

            Nav.NavigateTo("/");
        }
        finally
        {
            _busy = false;
        }
    }

    private sealed class RegisterModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required, MinLength(6)]
        public string Password { get; set; } = string.Empty;
    }
}

